{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"$lib/*": [
				"src/lib/*"
			],
			"$components/*": [
				"src/components/*"
			],
			"$styles/*": [
				"src/styles/*"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.astro",
		"./worker-configuration.d.ts"
	]
}